#!/usr/bin/env python
#MISE description="Most-used methods with their most common params (positional args: [method] [top_params]). Set PARQUET=path to switch input."

import os
import sys
import polars as pl

method_filter = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] != "-" else None
TOP_PARAMS = int(sys.argv[2]) if len(sys.argv) > 2 else (20 if method_filter else 5)
TOP_METHODS = 15

parquet = os.environ.get("PARQUET", "calls.parquet")
print(f"parquet: {parquet}")

df = pl.scan_parquet(parquet)

if method_filter:
    methods = [method_filter]
    counts = {method_filter: df.filter(pl.col("method") == method_filter).select(pl.len()).collect().item()}
else:
    top = (
        df.group_by("method")
          .agg(pl.len().alias("n"))
          .sort("n", descending=True)
          .head(TOP_METHODS)
          .collect()
    )
    methods = top["method"].to_list()
    counts = dict(zip(methods, top["n"].to_list()))

for m in methods:
    total = counts[m]
    by_params = (
        df.filter(pl.col("method") == m)
          .group_by("params_json")
          .agg(pl.len().alias("count"))
          .sort("count", descending=True)
          .collect()
    )
    distinct = by_params.height
    head = by_params.head(TOP_PARAMS)

    print(f"\n{m}  —  {total:,} calls, {distinct:,} distinct params")
    print(f"  {'count':>8}  params")
    for row in head.iter_rows(named=True):
        params = row["params_json"] or "<no params>"
        if len(params) > 180:
            params = params[:177] + "..."
        print(f"  {row['count']:>8}  {params}")
