#!/usr/bin/env python
#MISE description="Render the parquet + server-resource charts: per-node load-over-time (RPC demand + CPU/mem/disk + response) and a node-vs-node resource head-to-head (CPU/mem/disk, leaner node greens). Args: <node-a.parquet> <node-b.parquet> [out_dir=charts]. Run fetch-do first."

import sys
from pathlib import Path
from statistics import mean, median

# This task lives in mise-tasks/, but the chart toolkit (chart_kit) and the data
# layers (do_metrics, rpc_queries) live in the repo root. Put the root on sys.path
# so the imports resolve whether mise runs this file or it's run directly.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import altair as alt
import pandas as pd

import do_metrics as dm
import rpc_queries as rq
from chart_kit import (
    INK, FAINT, GREEN, RED, PURPLE, TEAL, STONE,
    style, save, per_flow, date_label, over_time_chart,
    colour_lower_better, node_legend,
)

# Resource charts keep the slightly larger title styling the deck has always used.
RES = dict(title_size=20, sub_size=13, sub_pad=8)


def parquet_span(path):
    """`(t0, span_hours)` for a parquet, from its first/last request."""
    pf = per_flow(path)
    t0 = float(pf["ts_start"].min())
    return t0, (float(pf["ts_start"].max()) - t0) / 3600


# ============== load + resources + latency over time (folds in resource-peak)
def load_over_time(path, w, node):
    """One node's "under real load" timeline: RPC demand, then whole-server
    CPU / memory / disk (each panel's title carries its avg/peak vs capacity, so
    the headroom story rides along), then median response. Folds in the old
    resource-peak chart — the avg/peak numbers live in the panel titles and disk
    is scaled to its full 619 GB so its low, flat usage reads as headroom.
    """
    pf = per_flow(path)
    t0 = float(pf["ts_start"].min())
    t1 = float(pf["ts_start"].max())
    clip = lambda s: [v for tt, v in s if t0 <= tt <= t1]
    cpu, mem, disk = clip(dm.cpu_series(w)), clip(dm.mem_series(w)), clip(dm.disk_series(w))
    total = dm.mem_stats(w)["total"]
    cores = dm.cpu_stats(w)["cores"]
    dsize = dm.disk_stats(w)["size"]
    resources = [
        {"df": dm.cpu_overlay(w, t0), "field": "cpu", "color": PURPLE,
         "title": f"server CPU used (%) — {cores} cores · avg {mean(cpu):.0f}% · peak {max(cpu):.0f}%"},
        {"df": dm.mem_overlay(w, t0), "field": "mem", "color": TEAL,
         "title": f"server memory used (GB) — of 32 GB · avg {mean(mem):.0f} GB ({100 * mean(mem) / total:.0f}%) "
                  f"· peak {max(mem):.0f} GB ({100 * max(mem) / total:.0f}%)"},
        {"df": dm.disk_overlay(w, t0), "field": "disk", "color": STONE, "domain": [0, dsize],
         "title": f"server disk used (GB) — of {dsize:.0f} GB · DB footprint ~{mean(disk):.0f} GB "
                  f"({100 * mean(disk) / dsize:.0f}%)"},
    ]
    return over_time_chart(path, resources=resources, node=node)


# --------------------------------- resource footprint (before-node baseline vs after-node)
def resource_compare(bp, ap, bw, aw):
    """Whole-server footprint at comparable load. The before node (A) is the grey
    baseline; the after node (B) carries the verdict colour — green when it runs
    leaner (less CPU / memory / disk for the same work), red when heavier. The move
    sits under each panel and the headline sums it up; builds self-label from the
    data via node_identity."""
    rps_a, rps_b = rq.headline(bp)["req_per_s"], rq.headline(ap)["req_per_s"]
    metrics = [  # (title, unit, fmt, A value, B value) — lower is leaner
        ("CPU used", "% of box", ".0f",
         dm.cpu_stats(bw)["util_mean"], dm.cpu_stats(aw)["util_mean"]),
        ("Memory used", "GB", ".1f",
         dm.mem_stats(bw)["used_mean"], dm.mem_stats(aw)["used_mean"]),
        ("Disk (DB footprint)", "GB", ".0f",
         dm.disk_stats(bw)["used_mean"], dm.disk_stats(aw)["used_mean"]),
    ]
    # One verdict colour for the after node, from the median move across the three
    # resources — green if it runs leaner overall (lower is better for all three).
    moves = [((vb - va) / va * 100 if va else 0.0) for _, _, _, va, vb in metrics]
    after_color = GREEN if median(moves) < 0 else RED if median(moves) > 0 else FAINT

    def panel(title, unit, fmt, va, vb):
        d = (vb - va) / va * 100 if va else 0.0
        df = pd.DataFrame([{"node": A_LBL, "node_label": A_FULL, "v": va},
                           {"node": B_LBL, "node_label": B_FULL, "v": vb}])
        base = alt.Chart(df).encode(
            x=alt.X("node:N", sort=[A_LBL, B_LBL], title=None, axis=alt.Axis(
                labelFontSize=13, labelFontWeight=600, labelColor=INK, labelAngle=0)),
            y=alt.Y("v:Q", title=unit, scale=alt.Scale(domain=[0, max(va, vb) * 1.28])))
        bars = base.mark_bar(size=64, cornerRadius=5).encode(
            color=node_legend([A_FULL, B_FULL], after_color))
        vlab = base.mark_text(dy=-9, fontSize=14, fontWeight=600, color=INK).encode(
            text=alt.Text("v:Q", format=fmt))
        return (bars + vlab).properties(width=220, height=300, title=alt.TitleParams(
            title, subtitle=f"{'down' if d < 0 else 'up'} {abs(d):.0f}%", fontSize=14,
            color=INK, anchor="start", subtitleColor=colour_lower_better(va, vb),
            subtitleFontSize=12.5, subtitleFontWeight=700))

    chart = alt.hconcat(*[panel(*m) for m in metrics], spacing=46).resolve_scale(color="shared")
    parts = [f"{title.split()[0].lower()} {'down' if d < 0 else 'up'} {abs(d):.0f}%"
             for (title, *_), d in zip(metrics, moves)]
    return style(chart, f"Resource footprint — {A_LBL} vs {B_LBL} at comparable load",
                 f"Improvement: {', '.join(parts)} — measured at {rps_a:.0f} vs {rps_b:.0f} req/s.",
                 **RES)


# ============================================================ render
if len(sys.argv) < 3:
    print("usage: mise run charts-do <before.parquet> <after.parquet> [out_dir=charts]",
          file=sys.stderr)
    sys.exit(2)
before_path, after_path = sys.argv[1], sys.argv[2]
out = Path(sys.argv[3] if len(sys.argv) > 3 else "charts")
out.mkdir(parents=True, exist_ok=True)
BEFORE_LBL = date_label(before_path)
AFTER_LBL = date_label(after_path)

bt0, bspan = parquet_span(before_path)
at0, aspan = parquet_span(after_path)
bw = dm.window_for(bt0, bspan)
aw = dm.window_for(at0, aspan)
missing = [f"{Path(p).name} ({lbl})"
           for p, win, lbl in ((before_path, bw, BEFORE_LBL), (after_path, aw, AFTER_LBL))
           if win is None]
if missing:
    have = ", ".join(dm.windows()) or "none"
    sys.exit(f"no server-metrics window overlaps {' and '.join(missing)} — "
             f"do-metrics/ has [{have}]. Pick runs that overlap a fetched window "
             f"(e.g. the may22→may26 baseline), or run `mise run fetch-do <parquet>` first "
             f"(note: metric retention may not reach runs more than ~a month old).")

# Warn (don't fail) if a run's clock range is only partly spanned by server-metric
# samples — measured as covered span / run span, so it's independent of the
# (range-dependent) sample cadence.
for tag, p, t0, span, w in [("before", before_path, bt0, bspan, bw),
                            ("after", after_path, at0, aspan, aw)]:
    inside = [t for t, _ in dm.cpu_series(w) if t0 <= t <= t0 + span * 3600]
    cov = (max(inside) - min(inside)) / (span * 3600) if len(inside) > 1 else 0.0
    if cov < 0.9:
        print(f"  note: {tag} run only ~{cov*100:.0f}% spanned by server-metrics window '{w}' "
              f"(metric retention may not reach that far back)", file=sys.stderr)

A = rq.node_identity(before_path)
B = rq.node_identity(after_path)
A_LBL, B_LBL = A["agent"], B["agent"]
if A_LBL == B_LBL:                        # same agent (two builds) -> disambiguate by commit
    A_LBL, B_LBL = f"{A['agent']} {A['commit'][:7]}", f"{B['agent']} {B['commit'][:7]}"
A_FULL, B_FULL = A["label"], B["label"]   # agent + version, for the node colour legend

print(f"A = {A['label']} ({bw})   B = {B['label']} ({aw})   ->  {out}")
save(load_over_time(before_path, bw, A_LBL), out / f"load-over-time-{A_LBL.lower().split()[0]}.png")
save(load_over_time(after_path,  aw, B_LBL), out / f"load-over-time-{B_LBL.lower().split()[0]}.png")
save(resource_compare(before_path, after_path, bw, aw), out / "resource-compare.png")
print("done")
