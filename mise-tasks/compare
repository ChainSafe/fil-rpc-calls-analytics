#!/usr/bin/env python
#MISE description="Per-method latency diff between two parquet files (args: <before.parquet> <after.parquet> [top_n] [sort] [--exclude=m1,m2] [--reweight])"

import sys
from pathlib import Path

import polars as pl

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
import rpc_queries as rq

# --exclude=eth_estimateGas,eth_call  (repeatable, comma-separated) drops those
# methods before any aggregation. Nothing is excluded by default.
# --reweight  adds mix-normalized overall blocks: both files are re-weighted to a
# shared (pooled) method mix so the overall difference reflects per-method speed,
# not which file happened to receive more of the slow methods. Off by default.
excluded: list[str] = []
reweight = False
positional: list[str] = []
for arg in sys.argv[1:]:
    if arg.startswith("--exclude=") or arg.startswith("-x="):
        excluded += [m.strip() for m in arg.split("=", 1)[1].split(",") if m.strip()]
    elif arg in ("--reweight", "-r"):
        reweight = True
    else:
        positional.append(arg)

if len(positional) < 2:
    print("usage: mise run compare <before.parquet> <after.parquet> [top_n=30] [sort=n|p50|p95|p99|mean] [--exclude=m1,m2] [--reweight]",
          file=sys.stderr)
    sys.exit(2)

before_path = positional[0]
after_path = positional[1]
top_n = int(positional[2]) if len(positional) > 2 else 30
sort_key = positional[3] if len(positional) > 3 else "n"


def drop_excluded(lf: pl.LazyFrame) -> pl.LazyFrame:
    return lf.filter(~pl.col("method").is_in(excluded)) if excluded else lf


def summarise(path: str) -> pl.DataFrame:
    return (
        drop_excluded(pl.scan_parquet(path))
          .filter(pl.col("batch_size") == 1)
          .group_by("method")
          .agg(
              pl.len().alias("n"),
              pl.col("duration_ms").mean().alias("mean"),
              pl.col("duration_ms").quantile(0.5).alias("p50"),
              pl.col("duration_ms").quantile(0.95).alias("p95"),
              pl.col("duration_ms").quantile(0.99).alias("p99"),
          )
          .collect()
    )


metrics = ["n", "mean", "p50", "p95", "p99"]
before = summarise(before_path).rename({c: f"{c}_a" for c in metrics})
after = summarise(after_path).rename({c: f"{c}_b" for c in metrics})
joined = before.join(after, on="method", how="full", coalesce=True)

deltas = joined.with_columns(
    (pl.col("mean_b") - pl.col("mean_a")).alias("d_mean"),
    (pl.col("p50_b") - pl.col("p50_a")).alias("d_p50"),
    (pl.col("p95_b") - pl.col("p95_a")).alias("d_p95"),
    (pl.col("p99_b") - pl.col("p99_a")).alias("d_p99"),
)

sort_col_map = {
    "n": pl.max_horizontal("n_a", "n_b"),
    "mean": pl.col("d_mean").abs(),
    "p50": pl.col("d_p50").abs(),
    "p95": pl.col("d_p95").abs(),
    "p99": pl.col("d_p99").abs(),
}
if sort_key not in sort_col_map:
    print(f"unknown sort key '{sort_key}', falling back to 'n'", file=sys.stderr)
    sort_key = "n"

ranked = deltas.sort(sort_col_map[sort_key], descending=True, nulls_last=True).head(top_n)

# Two narrow tables side-by-side is cramped in a terminal; print mean and percentile
# tables separately so each fits comfortably.
def render(title: str, metric: str, sub: pl.DataFrame) -> None:
    print(f"\n== {title} ==")
    table = sub.select(
        "method",
        pl.col("n_a").fill_null(0),
        pl.col("n_b").fill_null(0),
        pl.col(f"{metric}_a").round(1).alias("before"),
        pl.col(f"{metric}_b").round(1).alias("after"),
        pl.col(f"d_{metric}").round(1).alias("delta"),
    )
    with pl.Config(tbl_rows=top_n, tbl_width_chars=160, fmt_str_lengths=60):
        print(table)


print(f"before: {before_path}")
print(f"after:  {after_path}")
print(f"sort:   {sort_key}   top_n: {top_n}")
if excluded:
    print(f"excluded methods: {', '.join(excluded)}")


def overall(path: str) -> dict:
    df = drop_excluded(pl.scan_parquet(path)).filter(pl.col("duration_ms").is_not_null())
    flow = df.unique(subset=["flow_id"])
    f = flow.select(
        pl.col("duration_ms").mean().alias("avg"),
        pl.col("duration_ms").quantile(0.5, interpolation="lower").alias("p50"),
        pl.col("duration_ms").quantile(0.95, interpolation="lower").alias("p95"),
        pl.col("duration_ms").quantile(0.99, interpolation="lower").alias("p99"),
    ).collect().row(0)
    c = df.with_columns(
        (pl.col("duration_ms") / pl.col("batch_size")).alias("per_call_ms")
    ).select(
        pl.col("per_call_ms").mean().alias("avg"),
        pl.col("per_call_ms").quantile(0.5, interpolation="lower").alias("p50"),
        pl.col("per_call_ms").quantile(0.95, interpolation="lower").alias("p95"),
        pl.col("per_call_ms").quantile(0.99, interpolation="lower").alias("p99"),
    ).collect().row(0)
    return {"flow": f, "call": c}


def render_overall(title: str, kind: str, dp: int):
    a = oa[kind]; b = ob[kind]
    print(f"\n== overall {title} (ms, method-agnostic) ==")
    print(f"  {'metric':<6}  {'before':>10}  {'after':>10}  {'Δ':>10}  {'Δ%':>7}")
    for i, label in enumerate(["avg", "p50", "p95", "p99"]):
        bv, av = a[i], b[i]
        d = av - bv
        pct = (d / bv * 100) if bv else 0.0
        print(f"  {label:<6}  {bv:>10.{dp}f}  {av:>10.{dp}f}  {d:>+10.{dp}f}  {pct:>+6.1f}%")


def render_reweighted(title: str, a: tuple, b: tuple, dp: int):
    print(f"\n== overall {title} (ms, mix-normalized to pooled method mix) ==")
    print(f"  {'metric':<6}  {'before':>10}  {'after':>10}  {'Δ':>10}  {'Δ%':>7}")
    for i, label in enumerate(["avg", "p50", "p95", "p99"]):
        bv, av = a[i], b[i]
        d = av - bv
        pct = (d / bv * 100) if bv else 0.0
        print(f"  {label:<6}  {bv:>10.{dp}f}  {av:>10.{dp}f}  {d:>+10.{dp}f}  {pct:>+6.1f}%")


oa = overall(before_path)
ob = overall(after_path)
render_overall("per-flow latency", "flow", 1)
render_overall("per-call amortized (duration/batch_size)", "call", 2)

if reweight:
    ex = tuple(excluded)
    fa, fb = rq.per_flow_frame(before_path, ex), rq.per_flow_frame(after_path, ex)
    ca, cb = rq.per_call_frame(before_path, ex), rq.per_call_frame(after_path, ex)
    fref, cref = rq.ref_shares(fa, fb), rq.ref_shares(ca, cb)
    render_reweighted("per-flow latency", rq.reweighted_stats(fa, fref), rq.reweighted_stats(fb, fref), 1)
    render_reweighted("per-call amortized (duration/batch_size)",
                      rq.reweighted_stats(ca, cref), rq.reweighted_stats(cb, cref), 2)

render("mean (ms)", "mean", ranked)
render("p50 (ms)", "p50", ranked)
render("p95 (ms)", "p95", ranked)
render("p99 (ms)", "p99", ranked)
