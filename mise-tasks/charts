#!/usr/bin/env python
#MISE description="Render the parquet chart deck (all PNG): node-vs-node latency comparison (auto-labelled by version from the data) + single-capture business charts. Args: <node-a.parquet> <node-b.parquet> [top_n=30] [out_dir=charts] (or CHARTS_DIR env)."

import os
import sys
from pathlib import Path

# This task lives in mise-tasks/, but the chart toolkit (chart_kit) and the
# data layer (rpc_queries) live in the repo root. Put the root on sys.path so the
# imports resolve whether mise runs this file or it's run as `python mise-tasks/charts`.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import altair as alt
import numpy as np
import pandas as pd
import polars as pl

import rpc_queries as rq
from chart_kit import (
    INK, MUTED, GRID, FAINT, GREEN, RED, TEAL, BLUE, PURPLE, FONT, NEUTRAL,
    human, ms, style, save, per_flow, date_label, colour_lower_better, node_legend,
)


if len(sys.argv) < 3:
    print("usage: mise run charts <before.parquet> <after.parquet> [top_n=30] [out_dir=charts]",
          file=sys.stderr)
    sys.exit(2)

before_path = sys.argv[1]
after_path = sys.argv[2]
top_n = int(sys.argv[3]) if len(sys.argv) > 3 else 30
# out_dir: positional arg [4] wins, else CHARTS_DIR env, else "charts"
out_dir = Path(sys.argv[4] if len(sys.argv) > 4 else os.environ.get("CHARTS_DIR", "charts"))
out_dir.mkdir(parents=True, exist_ok=True)

# Identify the two nodes from the captured data (agent + version + commit) so the
# charts self-label which builds they compare, instead of generic "before/after".
A = rq.node_identity(before_path)   # node behind arg 1
B = rq.node_identity(after_path)    # node behind arg 2
A_LBL, B_LBL = A["agent"], B["agent"]            # short axis labels: "Forest" / "Lotus"
if A_LBL == B_LBL:                               # same agent (two builds) -> disambiguate by commit
    A_LBL, B_LBL = f"{A['agent']} {A['commit'][:7]}", f"{B['agent']} {B['commit'][:7]}"
VERSUS = f"{A['label']}   vs   {B['label']}"     # agent + version (no commit), for subtitles
A_FULL, B_FULL = A["label"], B["label"]          # agent + version, for the node colour legend

BEFORE_LBL = date_label(before_path)
AFTER_LBL = date_label(after_path)
GREY = FAINT  # the muted "before" baseline tone (the after node carries the verdict colour)


# ============================================================ latency dumbbells (PNG)
def latencies(path: str) -> dict[str, dict[str, float]]:
    df = pl.scan_parquet(path).filter(pl.col("duration_ms").is_not_null())
    flow = df.unique(subset=["flow_id"])
    f = flow.select(
        pl.col("duration_ms").mean().alias("avg"),
        pl.col("duration_ms").quantile(0.95).alias("p95"),
        pl.col("duration_ms").quantile(0.99).alias("p99"),
    ).collect().row(0, named=True)
    c = df.with_columns(
        (pl.col("duration_ms") / pl.col("batch_size")).alias("per_call_ms")
    ).select(
        pl.col("per_call_ms").mean().alias("avg"),
        pl.col("per_call_ms").quantile(0.95).alias("p95"),
        pl.col("per_call_ms").quantile(0.99).alias("p99"),
    ).collect().row(0, named=True)
    return {"per-flow": f, "per-call amortized": c}


a = latencies(before_path)
b = latencies(after_path)

rows = []
for view in ("per-flow", "per-call amortized"):
    for metric in ("avg", "p95", "p99"):
        rows.append({"view": view, "metric": metric, "phase": A_LBL,
                     "node_label": A_FULL, "ms": a[view][metric]})
        rows.append({"view": view, "metric": metric, "phase": B_LBL,
                     "node_label": B_FULL, "ms": b[view][metric]})
data = pl.DataFrame(rows).to_pandas()


def render(view: str, filename: str, title: str) -> None:
    sub = data[data["view"] == view].copy()
    deltas, parts, d_values = [], [], []
    for metric in ("avg", "p95", "p99"):
        a_ms = sub[(sub.metric == metric) & (sub.phase == A_LBL)]["ms"].iloc[0]
        b_ms = sub[(sub.metric == metric) & (sub.phase == B_LBL)]["ms"].iloc[0]
        d = (b_ms - a_ms) / a_ms * 100 if a_ms else 0.0
        d_values.append(d)
        verb = "down" if d < 0 else "up"
        deltas.append({"metric": metric, "label": f"{d:+.1f}%",
                       "color": colour_lower_better(a_ms, b_ms)})
        parts.append(f"{metric} {verb} {abs(d):.1f}% ({a_ms:.1f} → {b_ms:.1f} ms)")
    delta_df = pd.DataFrame(deltas)

    # One colour per node: the before node (A) is the grey baseline; the after node
    # (B) carries the overall verdict — green if the typical metric improved (fell),
    # red if it regressed. The per-metric direction lives in the Δ% row below.
    overall = float(np.median(d_values)) if d_values else 0.0
    after_color = GREEN if overall < 0 else RED if overall > 0 else FAINT

    base = alt.Chart(sub).encode(
        x=alt.X("phase:N", sort=[A_LBL, B_LBL], title=None,
                axis=alt.Axis(labelAngle=0, labelPadding=4),
                scale=alt.Scale(paddingInner=0.4, paddingOuter=0.3)),
        y=alt.Y("ms:Q", title="latency (ms)"),
    )
    bars = base.mark_bar(size=42).encode(
        color=node_legend([A_FULL, B_FULL], after_color),
        tooltip=["metric", "phase", alt.Tooltip("ms:Q", format=".1f")],
    )
    labels = base.mark_text(dy=-6, fontSize=11).encode(
        text=alt.Text("ms:Q", format=".1f"),
    )
    bar_chart = (
        alt.layer(bars, labels)
           .properties(width=170, height=280)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95", "p99"],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=40)
           .resolve_scale(y="independent")   # each metric its own scale (p99's tail won't crush avg/p95)
    )

    # Δ% row, faceted so each value sits under its metric panel.
    delta_chart = (
        alt.Chart(delta_df)
           .mark_text(fontSize=15, fontWeight="bold")
           .encode(text=alt.Text("label:N"), color=alt.Color("color:N", scale=None))
           .properties(width=170, height=24)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95", "p99"],
                                    title=None, header=alt.Header(labels=False)),
                  spacing=40)
    )

    chart = alt.vconcat(bar_chart, delta_chart).properties(
        title=alt.TitleParams(text=title, subtitle="Improvement: " + "; ".join(parts) + ".",
                              subtitleFontSize=11, subtitleColor="#555"),
    )
    save(chart, out_dir / filename)


def per_method(path: str) -> pl.DataFrame:
    """Per-method latency on singleton flows (matches the `compare` task)."""
    return (
        pl.scan_parquet(path)
          .filter(pl.col("batch_size") == 1)
          .group_by("method")
          .agg(
              pl.len().alias("n"),
              pl.col("duration_ms").mean().alias("mean"),
              pl.col("duration_ms").quantile(0.95).alias("p95"),
          )
          .collect()
    )


def _human(n: float) -> str:
    """Compact integer-ish formatting for call counts (e.g. 95438 -> 95.4k)."""
    n = float(n)
    for unit, div in (("M", 1e6), ("k", 1e3)):
        if abs(n) >= div:
            return f"{n / div:.1f}{unit}"
    return f"{n:.0f}"


def render_method(table: pl.DataFrame) -> None:
    """Three aligned dumbbell panels per method — call volume, mean latency and
    p95 latency. Every row reads left-to-right as Lotus (grey) → Forest, where
    Forest greens if it's faster and reds if it's slower; the call-volume panel is
    neutral blue since volume is neither a win nor a loss. Log x-scales keep the
    wide value ranges readable. The label on each latency row is Forest's change
    vs Lotus as a percent (− = faster), which reads more clearly than a raw
    millisecond difference."""
    import pandas as pd

    # Log axes can't plot null/zero, so keep methods present in both runs. A
    # method with a latency in both files also has n_a > 0 and n_b > 0.
    base = table.filter(
        pl.col("mean_a").is_not_null() & pl.col("mean_b").is_not_null()
    )
    order = base["method"].to_list()

    panels = [
        ("calls",     "n_a",    "n_b",    "count"),
        ("mean (ms)", "mean_a", "mean_b", "ms"),
        ("p95 (ms)",  "p95_a",  "p95_b",  "ms"),
    ]
    # The colour series double as the legend (auto-built from these labels):
    # Lotus is the grey baseline; Forest greens when faster, reds when slower;
    # call volume is neutral blue.
    S_LOTUS, S_FAST, S_SLOW, S_VOL = A_FULL, f"{B_FULL} faster", f"{B_FULL} slower", "call volume"
    series_domain = [S_LOTUS, S_FAST, S_SLOW, S_VOL]

    rows = []
    for panel, ca, cb, kind in panels:
        for r in base.iter_rows(named=True):
            bef, aft = r[ca], r[cb]
            if bef is None or aft is None:
                continue
            if kind == "count":
                label, after_series, lbl_color = _human(aft), S_VOL, INK
            else:
                pct = (aft - bef) / bef * 100 if bef else 0.0
                label = f"{pct:+.0f}%"
                after_series = S_FAST if pct < 0 else S_SLOW
                lbl_color = GREEN if pct < 0 else RED
            # before (Lotus) is always the grey baseline; the after (Forest) dot
            # carries the verdict (or neutral volume).
            rows.append({"method": r["method"], "panel": panel, "phase": A_LBL,
                         "value": bef, "before": bef, "after": aft,
                         "series": S_LOTUS, "label": None, "lbl_color": None})
            rows.append({"method": r["method"], "panel": panel, "phase": B_LBL,
                         "value": aft, "before": bef, "after": aft,
                         "series": after_series, "label": label, "lbl_color": lbl_color})

    long = pd.DataFrame(rows)

    y = alt.Y("method:N", sort=order, title=None,
              axis=alt.Axis(labelLimit=320, labelFontSize=11))
    logx = alt.Scale(type="log")
    after_only = alt.datum.phase == B_LBL
    color_enc = alt.Color("series:N", sort=series_domain,
                          scale=alt.Scale(domain=series_domain, range=[GREY, GREEN, RED, NEUTRAL]),
                          legend=alt.Legend(title=None, orient="bottom"))

    rules = alt.Chart(long).transform_filter(after_only).mark_rule(
        color=GREY, strokeWidth=2).encode(
        y=y, x=alt.X("before:Q", scale=logx, title=None), x2="after:Q",
    )
    points = alt.Chart(long).mark_point(filled=True, size=80).encode(
        y=y, x=alt.X("value:Q", scale=logx, title=None), color=color_enc,
        tooltip=["method", "panel", "phase", alt.Tooltip("value:Q", format=",.1f")],
    )
    labels = alt.Chart(long).transform_filter(after_only).mark_text(
        align="center", dy=-10, fontSize=9).encode(
        y=y, x=alt.X("after:Q", scale=logx), text="label:N",
        color=alt.Color("lbl_color:N", scale=None),
    )

    chart = (
        alt.layer(rules, points, labels)
           .properties(width=210, height=max(280, 22 * len(order)))
           .facet(column=alt.Column("panel:N", sort=[p[0] for p in panels],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=46)
           .resolve_scale(x="independent")
           .properties(title=alt.TitleParams(
               text=f"Per-method latency — {A_LBL} vs {B_LBL} (top {top_n} by calls)",
               subtitle="each row: Lotus → Forest · % = Forest's latency vs Lotus (− faster, + slower) · calls panel = volume",
               subtitleFontSize=11, subtitleColor="#555"))
    )
    save(chart, out_dir / "latency-per-method.png")


BUCKETS = ["2-10", "11-50", "51-99", "100+"]


def batch_table(path: str) -> pl.DataFrame:
    return (
        pl.scan_parquet(path)
          .filter(pl.col("batch_size") > 1)
          .group_by("flow_id")
          .agg(
              pl.col("batch_size").first(),
              pl.col("duration_ms").first(),
          )
          .with_columns(
              (pl.col("duration_ms") / pl.col("batch_size")).alias("per_call_ms"),
              pl.when(pl.col("batch_size") <= 10).then(pl.lit("2-10"))
                .when(pl.col("batch_size") <= 50).then(pl.lit("11-50"))
                .when(pl.col("batch_size") <= 99).then(pl.lit("51-99"))
                .otherwise(pl.lit("100+"))
                .alias("bucket"),
          )
          .collect()
    )


def batch_summary(path: str, col: str) -> pl.DataFrame:
    return (
        batch_table(path)
          .group_by("bucket")
          .agg(
              pl.len().alias("flows"),
              pl.col(col).mean().alias("avg"),
              pl.col(col).quantile(0.95).alias("p95"),
          )
    )


def render_batch(col: str, filename: str, title: str) -> None:
    """Horizontal dumbbells: bucket on y, latency on x (avg and p95). The before
    node (A) is the grey baseline; the after node (B) carries the verdict colour."""
    import pandas as pd

    sa = batch_summary(before_path, col)
    sb = batch_summary(after_path, col)
    rows, y_order, deltas = [], [], []
    metric_pcts = {"avg": [], "p95": []}
    for bucket in BUCKETS:
        ra = sa.filter(pl.col("bucket") == bucket)
        rb = sb.filter(pl.col("bucket") == bucket)
        if ra.is_empty() or rb.is_empty():
            continue
        ra, rb = ra.row(0, named=True), rb.row(0, named=True)
        fa, fb = ra["flows"], rb["flows"]
        y_order.append(f"({_human(fa)}→{_human(fb)} flows)  {bucket}")
        for metric in ("avg", "p95"):
            bef, aft = ra[metric], rb[metric]
            d_abs = aft - bef
            pct = (d_abs / bef * 100) if bef else 0.0
            deltas.append(d_abs)
            metric_pcts[metric].append(pct)
            lbl = f"{d_abs:+.1f} ({pct:+.1f}%)"
            lx = (bef * aft) ** 0.5
            bl = y_order[-1]
            label_fill = colour_lower_better(bef, aft)  # per-bucket Δ colour
            for phase, value, node_full in ((A_LBL, bef, A_FULL), (B_LBL, aft, B_FULL)):
                rows.append({"bucket": bucket, "bucket_label": bl, "metric": metric,
                             "phase": phase, "value": value,
                             "before": bef, "after": aft,
                             "flows_a": fa, "flows_b": fb,
                             "node_label": node_full,
                             "label": lbl if phase == B_LBL else None,
                             "label_x": lx if phase == B_LBL else None,
                             "label_color": label_fill if phase == B_LBL else None})

    summary = []
    for metric in ("avg", "p95"):
        vals = metric_pcts[metric]
        if not vals:
            continue
        m = float(np.median(vals))
        verb = "down" if m < 0 else "up"
        summary.append(f"{metric} {verb} {abs(m):.1f}%")

    long = pd.DataFrame(rows)
    overall = float(np.median(deltas)) if deltas else 0.0
    after_color = GREEN if overall < 0 else RED if overall > 0 else FAINT
    after_only = alt.datum.phase == B_LBL
    y = alt.Y("bucket_label:N", sort=y_order, title="batch size bucket",
              axis=alt.Axis(labelFontSize=11, titlePadding=8))
    logx = alt.Scale(type="log")

    rules = alt.Chart(long).transform_filter(after_only).mark_rule(
        color=GREY, strokeWidth=2).encode(
        y=y, x=alt.X("before:Q", scale=logx, title=None), x2="after:Q")
    points = alt.Chart(long).mark_point(filled=True, size=80).encode(
        y=y, x=alt.X("value:Q", scale=logx),
        color=node_legend([A_FULL, B_FULL], after_color),
        tooltip=["bucket", "metric", "phase",
                 alt.Tooltip("flows_a:Q", title="flows_a", format=","),
                 alt.Tooltip("flows_b:Q", title="flows_b", format=","),
                 alt.Tooltip("value:Q", format=".1f")])
    labels = alt.Chart(long).transform_filter(after_only).mark_text(
        align="center", dy=-10, fontSize=10).encode(
        y=y, x=alt.X("label_x:Q", scale=logx), text="label:N",
        color=alt.Color("label_color:N", scale=None, legend=None),
    )

    chart = (
        alt.layer(rules, points, labels)
           .properties(width=260, height=160)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95"],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=40)
           .resolve_scale(x="independent")
           .properties(title=alt.TitleParams(
               text=title,
               subtitle="Improvement: " + ", ".join(summary) + " (median across buckets).",
               subtitleFontSize=10, subtitleColor="#555"))
    )
    save(chart, out_dir / filename)


# ==================================================== reliability hero (deck opener)
def reliability_hero():
    """Bold opener: scale + reliability under real load as two big numbers over a
    full "answered" bar — not a stat grid. The supporting figures ride in one thin
    strip underneath so the eye lands on "millions of calls, all answered" first.
    """
    head = rq.headline(after_path)
    lf = pl.scan_parquet(after_path)
    total = head["calls"]
    # "answered" = Forest returned a response (a result OR a proper JSON-RPC error);
    # only a request with neither is a genuine no-answer.
    no_ans = lf.filter(pl.col("result_json").is_null() & pl.col("error_code").is_null()
                       ).select(pl.len()).collect().item()
    ans_pct = (total - no_ans) / total * 100
    ov = rq.overall_latency(after_path)
    p50, p95 = ov["per-flow"]["p50"], ov["per-flow"]["p95"]
    total_b = lf.unique(subset=["flow_id"]).select(pl.col("flow_resp_bytes").sum()).collect().item()
    cps, span_h = head["calls_per_s"], head["span_seconds"] / 3600
    methods = rq.distinct_methods(after_path)
    if no_ans == 0:
        ans_big, ans_sub = "100%", "answered — 0 dropped"
    elif ans_pct >= 99.95:
        ans_big, ans_sub = f"{ans_pct:.2f}%", "answered"
    else:
        ans_big, ans_sub = f"{ans_pct:.1f}%", f"answered — {human(no_ans)} no-response"

    def t(s, x, y, size, weight, color):
        return alt.Chart(pd.DataFrame([{"t": s}])).mark_text(
            align="left", baseline="middle", fontSize=size, fontWeight=weight,
            color=color, font=FONT).encode(x=alt.value(x), y=alt.value(y), text="t:N")

    def rect(x1, x2, y1, y2, fill, radius=0):
        return alt.Chart(pd.DataFrame([{"_": 0}])).mark_rect(fill=fill, cornerRadius=radius).encode(
            x=alt.value(x1), x2=alt.value(x2), y=alt.value(y1), y2=alt.value(y2))

    chips = (f"~{cps:.0f} calls/sec     ·     {span_h:.0f} h sustained     ·     {ms(p50)} typical"
             f"     ·     {ms(p95)} p95     ·     {methods} methods     ·     {total_b/1e9:.1f} GB served")
    hero = alt.layer(
        t(human(total), 60, 82, 80, 800, INK),
        t("RPC calls served", 64, 138, 17, 600, MUTED),
        t(ans_big, 600, 82, 80, 800, GREEN),
        t(ans_sub, 604, 138, 17, 600, MUTED),
        rect(60, 1080, 172, 196, GRID, 6),
        rect(60, 60 + 1020 * ans_pct / 100, 172, 196, GREEN, 6),
        t("every request got a response · real, sustained load", 60, 216, 13, 500, MUTED),
        t(chips, 60, 243, 14, 600, INK),
    ).properties(width=1140, height=265)
    return style(hero, "Forest under real load",
                 "the scale and reliability of a single Forest node")


# ============================ batching: most of the load, far cheaper per call
def batching_chart():
    """Two aligned panels by batch size: how many calls each carries (most ride
    in big batches) and what each call costs (far less in a batch).

    Baseline is eth_call ALONE vs eth_call IN A BATCH — apples to apples, because
    batches are ~99% eth_call and an eth_call genuinely costs ~41 ms on its own
    (it executes the EVM). Merges the old batch-scorecard (the 84%-of-calls fact)
    and batch-savings (the per-call cost), dropping the confounded before/after.
    """
    dist = {r["bucket"]: r for r in rq.batch_distribution(after_path).iter_rows(named=True)}
    total = sum(r["calls"] for r in dist.values())
    cost = {r["bucket"]: r["mean"] for r in
            rq.summarise_buckets(rq.batch_flows(after_path), "per_call_ms").iter_rows(named=True)}
    eth_alone = (pl.scan_parquet(after_path)
                 .filter((pl.col("batch_size") == 1) & (pl.col("method") == "eth_call"))
                 .select(pl.col("duration_ms").mean()).collect().item())
    cost["1"] = eth_alone

    lbls = {"1": "1  (eth_call alone)", "2-10": "2–10", "11-50": "11–50",
            "51-99": "51–99", "100+": "100+"}
    keys = ["1", "2-10", "11-50", "51-99", "100+"]
    rows = []
    for bk in keys:
        calls = dist.get(bk, {}).get("calls", 0)
        c = cost.get(bk)
        rows.append({"bucket": lbls[bk], "calls": calls, "cost": c,
                     "vlbl": f"{human(calls)}  ({calls / total * 100:.0f}%)",
                     "clbl": (f"{c:.0f} ms" if bk == "1"
                              else f"{c:.1f} ms · {eth_alone / c:.0f}× cheaper" if c else "")})
    df = pd.DataFrame(rows)
    order = [lbls[b] for b in keys]
    y = alt.Y("bucket:N", sort=order, title="calls bundled per request",
              axis=alt.Axis(labelFontSize=12, ticks=False, domain=False, titlePadding=10))

    vbars = alt.Chart(df).mark_bar(cornerRadiusEnd=4, color=TEAL, height=26).encode(
        y=y, x=alt.X("calls:Q", title=None, scale=alt.Scale(domain=[0, df["calls"].max() * 1.35]),
                     axis=alt.Axis(format="~s", grid=False, labels=False, ticks=False)))
    vtxt = alt.Chart(df).mark_text(align="left", dx=6, fontSize=12, fontWeight=700, color=INK).encode(
        y=y, x="calls:Q", text="vlbl:N")
    left = (vbars + vtxt).properties(width=300, height=240, title=alt.TitleParams(
        text="calls carried", anchor="start", fontSize=13.5, color=INK, dy=-4))

    cbars = alt.Chart(df).mark_bar(cornerRadiusEnd=4, height=26).encode(
        y=y, x=alt.X("cost:Q", title="cost per call (ms) · lower is better",
                     scale=alt.Scale(domain=[0, eth_alone * 1.2])),
        color=alt.Color("cost:Q", scale=alt.Scale(scheme="greens", reverse=True, domainMax=eth_alone),
                        legend=None))
    ctxt = alt.Chart(df).mark_text(align="left", dx=6, fontSize=12, fontWeight=700, color=INK).encode(
        y=y, x="cost:Q", text="clbl:N")
    right = (cbars + ctxt).properties(width=340, height=240, title=alt.TitleParams(
        text="cost per call", anchor="start", fontSize=13.5, color=INK, dy=-4))

    chart = alt.hconcat(left, right, spacing=54)
    bcalls = sum(dist.get(b, {}).get("calls", 0) for b in keys[1:])
    breqs = sum(dist.get(b, {}).get("flows", 0) for b in keys[1:])
    treqs = sum(r["flows"] for r in dist.values())
    big = cost["100+"]
    return style(chart, "Batching: most of the load rides in batches — and costs far less per call",
                 f"batches are {breqs / treqs * 100:.0f}% of requests but carry {bcalls / total * 100:.0f}% of all calls · "
                 f"an eth_call costs ~{eth_alone:.0f} ms alone but ~{big:.0f} ms in a 100+ batch "
                 f"({eth_alone / big:.0f}× cheaper), where {dist['100+']['calls'] / total * 100:.0f}% of calls ride")


# ===================== what one node serves: calls, breadth, data served
def mix_chart():
    """Three aligned panels by namespace — call volume, breadth (distinct
    methods) and data (response bytes). Each ranks the namespaces differently
    (eth dominates by calls, Filecoin has the widest API, trace pushes the most
    data), so one chart shows what a single Forest node actually serves. Folds
    in the old data-served chart, now grouped by namespace."""
    df = (rq.namespace_coverage(after_path)
            .join(rq.namespace_bytes(after_path), on="namespace", how="left")
            .with_columns(pl.col("bytes").fill_null(0))
            .filter(pl.col("namespace") != "other"))
    total = df["calls"].sum()
    df = df.with_columns((pl.col("calls") / total * 100).alias("share")).sort("calls", descending=True)
    order = df["namespace"].to_list()
    pdf = df.to_pandas()
    pdf["calls_lbl"] = [f"{human(c)}  ({s:.0f}%)" for c, s in zip(pdf["calls"], pdf["share"])]
    pdf["bytes_lbl"] = [f"{b/1e9:.2f} GB" if b >= 1e9 else f"{b/1e6:.0f} MB" if b >= 1e6
                        else f"{b/1e3:.0f} KB" if b > 0 else "—" for b in pdf["bytes"]]

    def panel(field, lbl_field, title, color, fmt, pad):
        base = alt.Chart(pdf).encode(y=alt.Y("namespace:N", sort=order, title=None,
                                             axis=alt.Axis(labelFontSize=12, ticks=False, domain=False)))
        bars = base.mark_bar(cornerRadiusEnd=4, height=22, color=color).encode(
            x=alt.X(f"{field}:Q", title=title, scale=alt.Scale(domain=[0, pdf[field].max() * pad]),
                    axis=alt.Axis(format=fmt, grid=False, labels=False, ticks=False)))
        txt = base.mark_text(align="left", dx=6, fontSize=12, fontWeight=700, color=INK).encode(
            x=f"{field}:Q", text=f"{lbl_field}:N" if lbl_field else alt.Text(f"{field}:Q", format=fmt))
        return (bars + txt).properties(width=250, height=210, title=alt.TitleParams(
            text=title, anchor="start", fontSize=13.5, color=INK, dy=-4))

    p_calls = panel("calls", "calls_lbl", "calls served", TEAL, "~s", 1.5)
    p_methods = panel("methods", None, "API surface — methods", BLUE, "d", 1.25)
    p_bytes = panel("bytes", "bytes_lbl", "data — response bytes", PURPLE, "~s", 1.5)
    chart = alt.hconcat(p_calls, p_methods, p_bytes, spacing=40)
    n = rq.distinct_methods(after_path)
    total_b = float(df["bytes"].sum())
    eth_share = float(pdf.loc[pdf.namespace == "eth", "share"].sum()) if (pdf.namespace == "eth").any() else 0.0
    top_data = pdf.sort_values("bytes", ascending=False).iloc[0]["namespace"]
    return style(chart, f"What one Forest node serves — {n} methods across {len(order)} namespaces",
                 f"eth is ~{eth_share:.0f}% of all calls · Filecoin is the widest API · "
                 f"{top_data} pushes most of the {total_b/1e9:.1f} GB served")


