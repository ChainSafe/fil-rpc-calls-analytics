def cdf_chart():
    qs = np.concatenate([np.linspace(0.01, 0.98, 80), np.linspace(0.981, 0.999, 20)])
    before_lbl, after_lbl = f"{BEFORE_LBL} (before)", f"{AFTER_LBL} (after)"
    rows, marks = [], []
    for label, path, color in [(before_lbl, before_path, FAINT),
                               (after_lbl, after_path, GREEN)]:
        s = per_flow(path)["duration_ms"]
        for q in qs:
            rows.append({"phase": label, "pctile": q * 100,
                         "ms": float(s.quantile(q)), "color": color})
        for q, nm in ((0.5, "median"), (0.95, "p95")):
            v = float(s.quantile(q))
            marks.append({"phase": label, "pctile": q * 100, "ms": v, "color": color,
                          "lbl": f"{nm} {v:.0f} ms" if v >= 10 else f"{nm} {v:.1f} ms"})
    df, mdf = pd.DataFrame(rows), pd.DataFrame(marks)

    X = alt.X("ms:Q", scale=alt.Scale(type="log", domain=[1, 2000]),
              title="response time (ms) · lower is better", axis=alt.Axis(format="~s"))
    Y = alt.Y("pctile:Q", title="% of requests answered this fast or faster",
              scale=alt.Scale(domain=[0, 100]))
    cscale = alt.Scale(domain=[before_lbl, after_lbl], range=[FAINT, GREEN])

    refs = alt.Chart(pd.DataFrame([{"y": 50, "t": "median"}, {"y": 95, "t": "95th %ile"}]))
    ref_lines = refs.mark_rule(color=GRID, strokeDash=[4, 4]).encode(y="y:Q")
    ref_text = refs.mark_text(align="left", dx=3, dy=-5, color=MUTED, fontSize=10.5).encode(
        y="y:Q", x=alt.value(2), text="t:N")
    line = alt.Chart(df).mark_line(strokeWidth=2.5).encode(
        x=X, y=Y, order="pctile:Q",
        color=alt.Color("phase:N", scale=cscale, legend=alt.Legend(title=None, orient="bottom-right")))
    dots = alt.Chart(mdf).mark_point(filled=True, size=80, stroke="white", strokeWidth=1).encode(
        x=X, y=Y, color=alt.Color("phase:N", scale=cscale, legend=None))
    # after (faster) sits left of before, so label after to its left and before to its right
    lbl_after = alt.Chart(mdf[mdf.phase == after_lbl]).mark_text(
        align="right", dx=-8, fontSize=11, fontWeight=700).encode(
        x=X, y=Y, text="lbl:N", color=alt.Color("color:N", scale=None, legend=None))
    lbl_before = alt.Chart(mdf[mdf.phase == before_lbl]).mark_text(
        align="left", dx=8, fontSize=11, fontWeight=700).encode(
        x=X, y=Y, text="lbl:N", color=alt.Color("color:N", scale=None, legend=None))

    chart = (ref_lines + ref_text + line + dots + lbl_after + lbl_before).properties(width=720, height=400)
    p95a = mdf[(mdf.phase == after_lbl) & (mdf.pctile == 95)]["ms"].iloc[0]
    p95b = mdf[(mdf.phase == before_lbl) & (mdf.pctile == 95)]["ms"].iloc[0]
    return style(chart, "How fast are requests answered?",
                 f"read “95% of requests answered within X ms”: {p95b:.0f} ms → {p95a:.0f} ms · "
                 "after-curve further left = faster")


def scorecard_chart():
    """Top methods as a shaded table: calls, mean & p95 before→after, coloured
    by how much each moved (green faster, red slower). Reads like a leaderboard.

    Methods with too few requests in the *before* run to compare reliably
    (e.g. trace_block had only 12) are left grey and marked, never coloured as a
    win or loss off a noisy baseline.
    """
    MIN_N = 100  # below this, the earlier run's baseline is statistical noise
    cols = ("n", "mean", "p95")
    a = rq.singleton_per_method(before_path).select("method", *cols).rename({c: f"{c}_a" for c in cols})
    b = rq.singleton_per_method(after_path).select("method", *cols).rename({c: f"{c}_b" for c in cols})
    top = rq.top_singleton_methods(after_path, 10)
    t = (b.join(a, on="method", how="left")
          .filter(pl.col("method").is_in(top) & pl.col("mean_a").is_not_null()))
    # preserve top-by-after-volume order
    t = t.with_columns(pl.col("method").replace_strict({m: i for i, m in enumerate(top)},
                       default=999).alias("_o")).sort("_o")

    COL = {"mean": "mean (ms)", "p95": "p95 (ms)"}
    rows, order, any_low = [], [], False
    for r in t.iter_rows(named=True):
        n_a = r["n_a"]
        low = n_a is not None and n_a < MIN_N
        any_low = any_low or low
        m = r["method"] + ("  *" if low else "")
        order.append(m)
        rows.append({"m": m, "col": "calls", "kind": "neutral",
                     "big": human(r["n_b"]), "small": "requests", "chg": 0.0})
        for key in ("mean", "p95"):
            bef, aft = r[f"{key}_a"], r[f"{key}_b"]
            d = (aft - bef) / bef * 100 if bef else 0.0
            if low:
                rows.append({"m": m, "col": COL[key], "kind": "neutral",
                             "big": f"{bef:.0f} → {aft:.0f}", "small": f"only {int(n_a)} before",
                             "chg": 0.0})
            else:
                small = "≈ same" if abs(d) < 3 else f"{'+' if d > 0 else '−'}{abs(d):.0f}%"
                rows.append({"m": m, "col": COL[key], "kind": "metric",
                             "big": f"{bef:.0f} → {aft:.0f}", "small": small,
                             "chg": max(-50, min(50, d))})
    df = pd.DataFrame(rows)
    xcols = ["calls", "mean (ms)", "p95 (ms)"]

    y = alt.Y("m:N", sort=order, title=None,
              axis=alt.Axis(labelFontSize=12, labelLimit=300, ticks=False, domain=False))
    x = alt.X("col:N", sort=xcols, title=None,
              axis=alt.Axis(orient="top", labelFontSize=12.5, labelFontWeight=700,
                            labelColor=INK, ticks=False, domain=False, labelPadding=8))
    neutral, metric = df[df.kind == "neutral"], df[df.kind == "metric"]
    # green (faster) ← white → red (slower); grey for un-comparable cells
    ncell = alt.Chart(neutral).mark_rect(stroke="white", strokeWidth=3, fill="#f1f5f9").encode(x=x, y=y)
    mcell = alt.Chart(metric).mark_rect(stroke="white", strokeWidth=3).encode(
        x=x, y=y, color=alt.Color("chg:Q",
            scale=alt.Scale(domain=[-50, 0, 50], range=["#86efac", "#ffffff", "#fca5a5"]),
            legend=None))
    big = alt.Chart(df).mark_text(dy=-7, fontSize=12.5, fontWeight=700, color=INK).encode(
        x=x, y=y, text="big:N")
    small = alt.Chart(df).mark_text(dy=10, fontSize=10.5, color=MUTED).encode(
        x=x, y=y, text="small:N")
    chart = (ncell + mcell + big + small).properties(width=360, height=42 * len(order))
    sub = (f"before → after on {BEFORE_LBL} vs {AFTER_LBL} · green = faster, red = slower "
           "(shaded by how much) · singletons only")
    if any_low:
        sub += " · * too few requests before to compare"
    return style(chart, "Top methods — calls, speed, and how each moved", sub)


def bandwidth_chart():
    """How much response data Forest pushed, and which methods are heaviest."""
    df = pl.scan_parquet(after_path)
    total = df.unique(subset=["flow_id"]).select(pl.col("flow_resp_bytes").sum()).collect().item()
    bym = (df.filter(pl.col("batch_size") == 1).group_by("method")
             .agg(pl.col("flow_resp_bytes").sum().alias("bytes"))
             .sort("bytes", descending=True).head(8).collect().to_pandas())
    bym["lbl"] = bym["bytes"].map(lambda b: f"{b/1e9:.2f} GB" if b >= 1e9 else f"{b/1e6:.0f} MB")
    y = alt.Y("method:N", sort="-x", title=None, axis=alt.Axis(labelFontSize=12))
    bars = alt.Chart(bym).mark_bar(cornerRadiusEnd=4, color=TEAL, height=22).encode(
        y=y, x=alt.X("bytes:Q", title="response bytes served (singletons)", axis=alt.Axis(format="~s")))
    lbl = alt.Chart(bym).mark_text(align="left", dx=6, fontSize=11.5, fontWeight=700, color=INK).encode(
        y=y, x="bytes:Q", text="lbl:N")
    chart = (bars + lbl).properties(width=600, height=300)
    top1 = bym.iloc[0]["method"]
    return style(chart, f"Data served — {total/1e9:.1f} GB of responses in {AFTER_LBL}",
                 f"heaviest singleton methods by total bytes returned · {top1} alone is most of it")


def load_latency_chart():
    df = per_flow(after_path)
    t0 = df["ts_start"].min()
    g = (df.with_columns((((pl.col("ts_start") - t0) / 600).floor()).alias("bin"))
           .group_by("bin").agg(pl.col("batch_size").sum().alias("calls"),
                                pl.col("duration_ms").quantile(0.95).alias("p95"))
           .with_columns((pl.col("calls") / 600).alias("calls_s")).to_pandas())
    pts = alt.Chart(g).mark_point(filled=True, size=70, color=TEAL, opacity=0.65).encode(
        x=alt.X("calls_s:Q", title="load — RPC calls / sec (each dot = a 10-min window)",
                scale=alt.Scale(zero=False)),
        y=alt.Y("p95:Q", title="p95 response time (ms)", scale=alt.Scale(zero=True)))
    trend = pts.transform_regression("calls_s", "p95").mark_line(color=RED, strokeWidth=2)
    chart = (pts + trend).properties(width=640, height=360)
    return style(chart, "Does Forest slow down under load?",
                 "p95 vs throughput across the run · a flat red trend = latency holds as load rises")


def error_chart():
    df = pl.scan_parquet(after_path)
    total = df.select(pl.len()).collect().item()
    success = df.filter(pl.col("result_json").is_not_null()).select(pl.len()).collect().item()
    errs = df.filter(pl.col("error_code").is_not_null())
    revert = errs.filter(
        pl.col("method").is_in(["eth_call", "eth_estimateGas", "eth_createAccessList"])
        | pl.col("error_message").str.contains("execution failed|failed to apply|revert").fill_null(False)
    ).select(pl.len()).collect().item()
    err_total = errs.select(pl.len()).collect().item()
    other_err = err_total - revert
    no_ans = total - success - err_total
    cats = [("answered — result returned", success, GREEN),
            ("contract revert — caller's tx reverts, returned correctly", revert, FAINT),
            ("genuine RPC error", other_err, RED),
            ("no answer", max(no_ans, 0), "#d1d5db")]
    rows = [{"cat": c, "calls": n, "color": col, "pctval": n / total * 100,
             "lbl": f"{human(n)}  ({n/total*100:.1f}%)"} for c, n, col in cats if n > 0]
    df2 = pd.DataFrame(rows)
    order = [r["cat"] for r in rows]
    y = alt.Y("cat:N", sort=order, title=None, axis=alt.Axis(labelLimit=420, labelFontSize=12))
    bars = alt.Chart(df2).mark_bar(cornerRadiusEnd=4, height=30).encode(
        y=y, x=alt.X("calls:Q", title="calls", axis=alt.Axis(format="~s")),
        color=alt.Color("color:N", scale=None, legend=None))
    lbl = alt.Chart(df2).mark_text(align="left", dx=6, fontSize=12, fontWeight=700, color=INK).encode(
        y=y, x="calls:Q", text="lbl:N")
    chart = (bars + lbl).properties(width=620, height=44 * len(rows))
    return style(chart, "The honest error rate isn’t 80% — it’s a fraction of a percent",
                 f"most “errors” are eth_call contract reverts Forest returns correctly · "
                 f"genuine failures = {other_err/total*100:.1f}% · {AFTER_LBL}")


