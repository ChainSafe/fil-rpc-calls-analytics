#!/usr/bin/env python
#MISE description="Render latency comparison charts (Altair SVG). Node+version auto-detected from filenames (calls-<node>-<version>.parquet). Args: <before.parquet> <after.parquet> [top_n=30]. CHARTS_DIR=out."

import os
import re
import statistics
import sys
from pathlib import Path

import altair as alt
import pandas as pd
import polars as pl


if len(sys.argv) < 3:
    print("usage: mise run charts <before.parquet> <after.parquet>", file=sys.stderr)
    sys.exit(2)

before_path = sys.argv[1]
after_path = sys.argv[2]
top_n = int(sys.argv[3]) if len(sys.argv) > 3 else 10
out_dir = Path(os.environ.get("CHARTS_DIR", "charts"))
out_dir.mkdir(exist_ok=True)

GREEN = "#16a34a"
GREY  = "#9ca3af"
RED   = "#dc2626"
BLUE  = "#2563eb"


def verdict_color(before: float, after: float) -> str:
    """Verdict colour for a before→after pair on our shared palette: green when
    it improved (after is lower), red when it regressed, grey when unchanged."""
    return GREEN if after < before else RED if after > before else GREY


def node_legend(color_field: str, domain: list[str], after_color: str) -> alt.Color:
    """The two-entry node colour legend shared by the bar and dumbbell charts:
    the first label in `domain` (before node) is grey, the second (after node)
    takes `after_color`. `color_field` is the data column holding the label."""
    return alt.Color(f"{color_field}:N", sort=domain,
                     scale=alt.Scale(domain=domain, range=[GREY, after_color]),
                     legend=alt.Legend(title=None, orient="bottom"))


def node_and_version(path: str) -> tuple[str, str]:
    """Best-effort (node, version) from a capture filename in the expected
    form calls-<node>-<version>.parquet, e.g.
    calls-forest-1.2.parquet  -> ("forest", "1.2"),
    calls-lotus-v1.18.parquet -> ("lotus", "v1.18"),
    calls-forest2.parquet     -> ("forest", "")   (no version, legacy).
    Strips the capture prefix (calls/flows) and any trailing run digits on the
    node, and treats everything after the first separator as the version."""
    stem = Path(path).stem
    stem = re.sub(r"^(calls|flows)[-_. ]*", "", stem, flags=re.IGNORECASE)
    node, _, version = stem.partition("-")
    node = re.sub(r"\d+$", "", node).lower() or node.lower()
    return node, version.strip("-_. ")


def labelled(name: str, version: str) -> str:
    return f"{name} {version}".strip() if version else name


before_name, before_version = node_and_version(before_path)
after_name, after_version = node_and_version(after_path)
before_label = labelled(before_name, before_version)
after_label = labelled(after_name, after_version)
# If the two captures can't be told apart by node name (same node, or neither
# parsed to a real name), fall back to plain before/after everywhere so titles
# read sensibly and the bar x-axis categories don't collide.
if before_name == after_name:
    before_name, after_name = "before", "after"
    before_label, after_label = "before", "after"


def latencies(path: str) -> dict[str, dict[str, float]]:
    df = pl.scan_parquet(path).filter(pl.col("duration_ms").is_not_null())
    flow = df.unique(subset=["flow_id"])
    f = flow.select(
        pl.col("duration_ms").mean().alias("avg"),
        pl.col("duration_ms").quantile(0.95).alias("p95"),
        pl.col("duration_ms").quantile(0.99).alias("p99"),
    ).collect().row(0, named=True)
    c = df.with_columns(
        (pl.col("duration_ms") / pl.col("batch_size")).alias("per_call_ms")
    ).select(
        pl.col("per_call_ms").mean().alias("avg"),
        pl.col("per_call_ms").quantile(0.95).alias("p95"),
        pl.col("per_call_ms").quantile(0.99).alias("p99"),
    ).collect().row(0, named=True)
    return {"per-flow": f, "per-call amortized": c}


a = latencies(before_path)
b = latencies(after_path)

rows = []
for view in ("per-flow", "per-call amortized"):
    for metric in ("avg", "p95", "p99"):
        rows.append({"view": view, "metric": metric, "phase": "before",
                     "node": before_name, "node_label": before_label, "ms": a[view][metric]})
        rows.append({"view": view, "metric": metric, "phase": "after",
                     "node": after_name, "node_label": after_label, "ms": b[view][metric]})
data = pl.DataFrame(rows).to_pandas()


def render(view: str, filename: str, title: str) -> None:
    sub = data[data["view"] == view].copy()
    deltas, sentence_parts, after_fill, d_values = [], [], {}, []
    for metric in ("avg", "p95", "p99"):
        before_ms = sub.loc[(sub.metric == metric) & (sub.phase == "before"), "ms"].iloc[0]
        after_ms  = sub.loc[(sub.metric == metric) & (sub.phase == "after"), "ms"].iloc[0]
        d = (after_ms - before_ms) / before_ms * 100 if before_ms else 0.0
        d_values.append(d)
        after_fill[metric] = verdict_color(before_ms, after_ms)
        verb = "down" if d < 0 else "up"
        deltas.append({"metric": metric, "label": f"{d:+.1f}%", "fill": after_fill[metric]})
        sentence_parts.append(f"{metric} {verb} {abs(d):.1f}% ({before_ms:.1f} → {after_ms:.1f} ms)")
    delta_df = pd.DataFrame(deltas)

    # One colour per node: grey baseline, after = the overall verdict (green if
    # the typical metric improved). Per-metric direction stays in the Δ% row.
    overall = statistics.median(d_values) if d_values else 0.0
    after_color = GREEN if overall < 0 else RED if overall > 0 else GREY
    node_domain = [before_label, after_label]

    base = alt.Chart(sub).encode(
        x=alt.X("node:N", sort=[before_name, after_name], title=None,
                axis=alt.Axis(labelAngle=0, labelPadding=4),
                scale=alt.Scale(paddingInner=0.4, paddingOuter=0.3)),
        y=alt.Y("ms:Q", title="latency (ms)"),
    )
    bars = base.mark_bar(size=42).encode(
        color=node_legend("node_label", node_domain, after_color),
        tooltip=["metric", "node", "phase", alt.Tooltip("ms:Q", format=".1f")],
    )
    labels = base.mark_text(dy=-6, fontSize=11).encode(
        text=alt.Text("ms:Q", format=".1f"),
    )
    bar_chart = (
        alt.layer(bars, labels)
           .properties(width=170, height=280)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95", "p99"],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=40)
    )

    # Delta percentage row, faceted so it aligns under each metric panel.
    delta_chart = (
        alt.Chart(delta_df)
           .mark_text(fontSize=15, fontWeight="bold")
           .encode(text=alt.Text("label:N"), color=alt.Color("fill:N", scale=None))
           .properties(width=170, height=24)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95", "p99"],
                                    title=None, header=alt.Header(labels=False)),
                  spacing=40)
    )

    sentence = "Improvement: " + "; ".join(sentence_parts) + "."

    chart = alt.vconcat(bar_chart, delta_chart).properties(
        title=alt.TitleParams(text=title, subtitle=sentence, subtitleFontSize=11, subtitleColor="#555"),
    )
    path = out_dir / filename
    chart.save(str(path))
    print(f"  wrote {path}")


def per_method(path: str) -> pl.DataFrame:
    """Per-method latency on singleton flows (matches the `compare` task)."""
    return (
        pl.scan_parquet(path)
          .filter(pl.col("batch_size") == 1)
          .group_by("method")
          .agg(
              pl.len().alias("n"),
              pl.col("duration_ms").mean().alias("mean"),
              pl.col("duration_ms").quantile(0.95).alias("p95"),
          )
          .collect()
    )


def _human(n: float) -> str:
    """Compact integer-ish formatting for call counts (e.g. 95438 -> 95.4k)."""
    n = float(n)
    for unit, div in (("M", 1e6), ("k", 1e3)):
        if abs(n) >= div:
            return f"{n / div:.1f}{unit}"
    return f"{n:.0f}"


def render_method(table: pl.DataFrame) -> None:
    """One combined chart with three aligned before→after dumbbell panels per
    method: call volume (n_a→n_b), mean latency, and p95 latency. All on log
    x-scales so the wide value ranges stay readable, and the shared method rows
    let you read traffic, typical cost, and tail cost together."""
    # Log axes can't plot null/zero, so keep methods present in both runs. A
    # method with a latency in both files also has n_a > 0 and n_b > 0.
    base = (
        table.filter(pl.col("mean_a").is_not_null() & pl.col("mean_b").is_not_null())
              .with_columns(pl.max_horizontal("n_a", "n_b").alias("_calls"))
              .sort("_calls", descending=True)
    )
    order = base["method"].to_list()

    panels = [
        ("calls",     "n_a",    "n_b",    "count"),
        ("mean (ms)", "mean_a", "mean_b", "ms"),
        ("p95 (ms)",  "p95_a",  "p95_b",  "ms"),
    ]

    rows = []
    for panel, ca, cb, kind in panels:
        for r in base.iter_rows(named=True):
            bef, aft = r[ca], r[cb]
            if bef is None or aft is None:
                continue
            d = aft - bef
            label = (f"{'+' if d >= 0 else '-'}{_human(abs(d))}"
                     if kind == "count" else f"{d:+.1f}")
            fill = BLUE if kind == "count" else verdict_color(bef, aft)
            for phase, value in (("before", bef), ("after", aft)):
                rows.append({"method": r["method"], "panel": panel,
                             "phase": phase, "value": value,
                             "before": bef, "after": aft, "label": label,
                             "fill": fill})

    long = pd.DataFrame(rows)

    y = alt.Y("method:N", sort=order, title=None,
              axis=alt.Axis(labelLimit=320, labelFontSize=11))
    logx = alt.Scale(type="log")
    after_only = alt.datum.phase == "after"

    rules = alt.Chart(long).transform_filter(after_only).mark_rule(
        color=GREY, strokeWidth=2).encode(
        y=y, x=alt.X("before:Q", scale=logx, title=None), x2="after:Q",
    )
    fill_scale = alt.Scale(
        domain=[GREEN, RED, GREY, BLUE], range=[GREEN, RED, GREY, BLUE])
    points = alt.Chart(long).mark_point(filled=True, size=80).encode(
        y=y, x=alt.X("value:Q", scale=logx, title=None),
        color=alt.condition(
            alt.datum.phase == "before", alt.value(GREY),
            alt.Color("fill:N", scale=fill_scale, legend=None)),
        tooltip=["method", "panel", "phase", alt.Tooltip("value:Q", format=",.1f")],
    )
    labels = alt.Chart(long).transform_filter(after_only).mark_text(
        align="center", dy=-10, fontSize=9).encode(
        y=y, x=alt.X("after:Q", scale=logx), text="label:N",
        color=alt.Color("fill:N", scale=None),
    )

    chart = (
        alt.layer(rules, points, labels)
           .properties(width=210, height=max(280, 22 * len(order)))
           .facet(column=alt.Column("panel:N", sort=[p[0] for p in panels],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=46)
           .resolve_scale(x="independent")
           .configure_legend(disable=True)
           .properties(title=alt.TitleParams(
               text=f"Per-method latency: {before_name} and {after_name} performance diff (top {top_n} by calls)",
               subtitle="calls panel = traffic volume (n_a→n_b); labels = Δ",
               subtitleFontSize=11, subtitleColor="#555"))
    )
    path = out_dir / "latency-per-method.svg"
    chart.save(str(path))
    print(f"  wrote {path}")


BUCKETS = ["2-10", "11-50", "51-99", "100+"]


def batch_table(path: str) -> pl.DataFrame:
    return (
        pl.scan_parquet(path)
          .filter(pl.col("batch_size") > 1)
          .group_by("flow_id")
          .agg(
              pl.col("batch_size").first(),
              pl.col("duration_ms").first(),
          )
          .with_columns(
              (pl.col("duration_ms") / pl.col("batch_size")).alias("per_call_ms"),
              pl.when(pl.col("batch_size") <= 10).then(pl.lit("2-10"))
                .when(pl.col("batch_size") <= 50).then(pl.lit("11-50"))
                .when(pl.col("batch_size") <= 99).then(pl.lit("51-99"))
                .otherwise(pl.lit("100+"))
                .alias("bucket"),
          )
          .collect()
    )


def batch_summary(path: str, col: str) -> pl.DataFrame:
    return (
        batch_table(path)
          .group_by("bucket")
          .agg(
              pl.len().alias("flows"),
              pl.col(col).mean().alias("avg"),
              pl.col(col).quantile(0.95).alias("p95"),
          )
    )


def render_batch(col: str, filename: str, title: str) -> None:
    """Horizontal dumbbells: bucket on y, latency on x (avg and p95)."""
    sa = batch_summary(before_path, col)
    sb = batch_summary(after_path, col)
    rows, y_order, deltas = [], [], []
    metric_pcts: dict[str, list[float]] = {"avg": [], "p95": []}
    for bucket in BUCKETS:
        ra = sa.filter(pl.col("bucket") == bucket)
        rb = sb.filter(pl.col("bucket") == bucket)
        if ra.is_empty() or rb.is_empty():
            continue
        ra, rb = ra.row(0, named=True), rb.row(0, named=True)
        fa, fb = ra["flows"], rb["flows"]
        y_order.append(f"{bucket}   ({_human(fa)}→{_human(fb)} flows)")
        for metric in ("avg", "p95"):
            bef, aft = ra[metric], rb[metric]
            d_abs = aft - bef
            pct = (d_abs / bef * 100) if bef else 0.0
            deltas.append(d_abs)
            metric_pcts[metric].append(pct)
            label_fill = verdict_color(bef, aft)
            lbl = f"{d_abs:+.1f} ({pct:+.1f}%)"
            lx = (bef * aft) ** 0.5
            bl = y_order[-1]
            for phase, value in (("before", bef), ("after", aft)):
                rows.append({"bucket": bucket, "bucket_label": bl, "metric": metric,
                             "phase": phase, "value": value,
                             "before": bef, "after": aft,
                             "flows_a": fa, "flows_b": fb,
                             "label": lbl if phase == "after" else None,
                             "label_x": lx if phase == "after" else None,
                             "fill": label_fill,
                             "node": before_label if phase == "before" else after_label})

    summary = []
    for metric in ("avg", "p95"):
        vals = metric_pcts[metric]
        if not vals:
            continue
        m = statistics.median(vals)
        verb = "down" if m < 0 else "up"
        summary.append(f"{metric} {verb} {abs(m):.1f}%")

    long = pd.DataFrame(rows)
    overall = statistics.median(deltas) if deltas else 0.0
    after_color = GREEN if overall < 0 else RED if overall > 0 else GREY
    node_domain = [before_label, after_label]
    after_only = alt.datum.phase == "after"
    y = alt.Y("bucket_label:N", sort=y_order, title="batch size buckets",
              axis=alt.Axis(labelFontSize=11, titlePadding=8))
    logx = alt.Scale(type="log")

    rules = alt.Chart(long).transform_filter(after_only).mark_rule(
        color=GREY, strokeWidth=2).encode(
        y=y, x=alt.X("before:Q", scale=logx, title=None), x2="after:Q")
    points = alt.Chart(long).mark_point(filled=True, size=80).encode(
        y=y, x=alt.X("value:Q", scale=logx),
        color=node_legend("node", node_domain, after_color),
        tooltip=["bucket", "metric", "node",
                 alt.Tooltip("flows_a:Q", title=f"{before_name} flows", format=","),
                 alt.Tooltip("flows_b:Q", title=f"{after_name} flows", format=","),
                 alt.Tooltip("value:Q", format=".1f")])
    labels = alt.Chart(long).transform_filter(after_only).mark_text(
        align="center", dy=-10, fontSize=10).encode(
        y=y, x=alt.X("label_x:Q", scale=logx), text="label:N",
        color=alt.Color("fill:N", scale=None, legend=None),
    )

    chart = (
        alt.layer(rules, points, labels)
           .properties(width=260, height=160)
           .facet(column=alt.Column("metric:N", sort=["avg", "p95"],
                                    title=None, header=alt.Header(labelFontSize=13)),
                  spacing=40)
           .resolve_scale(x="independent")
           .properties(title=alt.TitleParams(
               text=title,
               subtitle="Improvement: " + ", ".join(summary) + " (median across buckets).",
               subtitleFontSize=10, subtitleColor="#555"))
    )
    path = out_dir / filename
    chart.save(str(path))
    print(f"  wrote {path}")


print(f"before: {before_path}  (node: {before_name})")
print(f"after:  {after_path}  (node: {after_name})")
render("per-flow",            "latency-per-flow.svg",
       f"Per-flow latency: {before_name} vs {after_name} (ms)")
render("per-call amortized",  "latency-per-call.svg",
       f"Per-call amortized latency: {before_name} vs {after_name} (ms)")

qcols = ("n", "mean", "p95")
ma = per_method(before_path).rename({c: f"{c}_a" for c in qcols})
mb = per_method(after_path).rename({c: f"{c}_b" for c in qcols})
method_table = (
    ma.join(mb, on="method", how="full", coalesce=True)
      .sort(pl.max_horizontal("n_a", "n_b"), descending=True, nulls_last=True)
      .head(top_n)
)
render_method(method_table)

render_batch("duration_ms", "latency-batch-per-flow.svg",
             f"Batched per-flow duration: {before_name} vs {after_name} (ms)")
render_batch("per_call_ms", "latency-batch-per-call.svg",
             f"Batched per-call amortized: {before_name} vs {after_name} (ms)")
