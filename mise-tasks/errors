#!/usr/bin/env python
#MISE description="Error rates by JSON-RPC method (top 30 by call count). Set PARQUET=path to switch input."

import os
import polars as pl

parquet = os.environ.get("PARQUET", "calls.parquet")
print(f"parquet: {parquet}")

df = pl.scan_parquet(parquet)

out = (
    df.group_by("method")
      .agg(
          pl.len().alias("calls"),
          pl.col("error_code").is_not_null().sum().alias("errors"),
          (pl.col("error_code").is_not_null().mean() * 100).round(2).alias("err_pct"),
      )
      .sort("calls", descending=True)
      .head(30)
      .collect()
)

with pl.Config(tbl_rows=30, tbl_width_chars=120):
    print(out)
