#!/usr/bin/env python
#MISE description="Top N slowest flows (positional args: [method] [top_n]). Set PARQUET=path to switch input."

import os
import sys
import polars as pl

method = sys.argv[1] if len(sys.argv) > 1 and sys.argv[1] != "-" else None
top_n = int(sys.argv[2]) if len(sys.argv) > 2 else 15

parquet = os.environ.get("PARQUET", "calls.parquet")
# Truncation caps (chars). Set to 0 for no truncation.
params_cap = int(os.environ.get("PARAMS_CAP", "200"))
error_cap = int(os.environ.get("ERROR_CAP", "80"))
print(f"parquet: {parquet}")

df = pl.scan_parquet(parquet)
if method:
    df = df.filter(pl.col("method") == method)

# Dedupe by flow_id so batch=N flows don't fill the list with the same row N times.
out = (
    df.sort("duration_ms", descending=True, nulls_last=True)
      .unique(subset=["flow_id"], keep="first", maintain_order=True)
      .head(top_n)
      .select(
          pl.col("duration_ms").round(1),
          "batch_size",
          "method",
          "error_code",
          pl.col("error_message").str.slice(0, error_cap) if error_cap else pl.col("error_message"),
          pl.col("params_json").str.slice(0, params_cap) if params_cap else pl.col("params_json"),
      )
      .collect()
)

uncapped = not (params_cap and error_cap)
fmt_len = 100000 if uncapped else 200
tbl_width = 65535 if uncapped else 240
with pl.Config(fmt_str_lengths=fmt_len, tbl_width_chars=tbl_width, tbl_rows=top_n):
    print(out)
