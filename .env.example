# Copy to .env and fill in. Used by fetch_do.py (`mise run fetch-do`).
# .env is gitignored; this example is safe to commit.

# DigitalOcean API token — a read-only token is enough.
DIGITALOCEAN_TOKEN=dop_v1_xxxxxxxxxxxx

# The droplet's numeric host id (use the id, not the name — names can change).
DIGITALOCEAN_HOST_ID=000000000
